         MFLD  (PR6TRM,LTH=5)
         MFLD  (PR6MIL,LTH=7)
         MFLD  (PR6RTL,LTH=8)
         MFLD  (PR6CST,LTH=8)
         MFLD  (PR6PRF,LTH=8)
*        PRODUCT LINE 7: TIRE & WHEEL
