*---------------------------------------------------------------*
*  MFS SCREEN: F&I PRODUCT MENU                                  *
*  TRANSACTION: AUTOFNPR                                         *
*  DESCRIPTION: Finance & Insurance aftermarket product menu     *
*---------------------------------------------------------------*
         PRINT NOGEN
*
* MESSAGE INPUT DESCRIPTOR
*
FINPRI   MID
         SEG
         MFLD  'AUTOFNPR',LTH=8
         MFLD  DEALNUM,LTH=8
         MFLD  SEL01,LTH=1
         MFLD  SEL02,LTH=1
         MFLD  SEL03,LTH=1
         MFLD  SEL04,LTH=1
         MFLD  SEL05,LTH=1
         MFLD  SEL06,LTH=1
         MFLD  SEL07,LTH=1
         MFLD  SEL08,LTH=1
         MFLD  SEL09,LTH=1
         MFLD  SEL10,LTH=1
         MSGEND
*
* MESSAGE OUTPUT DESCRIPTOR
*
FINPRO   MOD
         SEG
         MFLD  (DEALNUM,LTH=8)
         MFLD  (CSNAME,LTH=25)
         MFLD  (VHYMM,LTH=20)
*        PRODUCT LINE 1: EXTENDED WARRANTY
         MFLD  (SEL01,LTH=1)
         MFLD  (PR1NAM,LTH=14)
         MFLD  (PR1TRM,LTH=5)
         MFLD  (PR1MIL,LTH=7)
         MFLD  (PR1RTL,LTH=8)
         MFLD  (PR1CST,LTH=8)
         MFLD  (PR1PRF,LTH=8)
*        PRODUCT LINE 2: GAP INSURANCE
         MFLD  (SEL02,LTH=1)
         MFLD  (PR2NAM,LTH=14)
         MFLD  (PR2TRM,LTH=5)
         MFLD  (PR2MIL,LTH=7)
         MFLD  (PR2RTL,LTH=8)
         MFLD  (PR2CST,LTH=8)
         MFLD  (PR2PRF,LTH=8)
*        PRODUCT LINE 3: PAINT PROTECTION
         MFLD  (SEL03,LTH=1)
