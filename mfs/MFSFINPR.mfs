         MFLD  (PR7TRM,LTH=5)
         MFLD  (PR7MIL,LTH=7)
         MFLD  (PR7RTL,LTH=8)
         MFLD  (PR7CST,LTH=8)
         MFLD  (PR7PRF,LTH=8)
*        PRODUCT LINE 8: DENT REPAIR
         MFLD  (SEL08,LTH=1)
         MFLD  (PR8NAM,LTH=14)
         MFLD  (PR8TRM,LTH=5)
         MFLD  (PR8MIL,LTH=7)
         MFLD  (PR8RTL,LTH=8)
         MFLD  (PR8CST,LTH=8)
         MFLD  (PR8PRF,LTH=8)
*        PRODUCT LINE 9: KEY REPLACEMENT
