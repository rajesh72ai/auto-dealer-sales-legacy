         MFLD  (PR4RTL,LTH=8)
         MFLD  (PR4CST,LTH=8)
         MFLD  (PR4PRF,LTH=8)
*        PRODUCT LINE 5: THEFT DETERRENT
         MFLD  (SEL05,LTH=1)
         MFLD  (PR5NAM,LTH=14)
         MFLD  (PR5TRM,LTH=5)
         MFLD  (PR5MIL,LTH=7)
         MFLD  (PR5RTL,LTH=8)
         MFLD  (PR5CST,LTH=8)
         MFLD  (PR5PRF,LTH=8)
*        PRODUCT LINE 6: MAINTENANCE PLAN
