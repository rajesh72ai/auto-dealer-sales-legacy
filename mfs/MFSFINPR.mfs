         MFLD  (PR9NAM,LTH=14)
         MFLD  (PR9TRM,LTH=5)
         MFLD  (PR9MIL,LTH=7)
         MFLD  (PR9RTL,LTH=8)
         MFLD  (PR9CST,LTH=8)
         MFLD  (PR9PRF,LTH=8)
*        PRODUCT LINE 10: LOJACK
