         MFLD  (PR3TRM,LTH=5)
         MFLD  (PR3MIL,LTH=7)
         MFLD  (PR3RTL,LTH=8)
         MFLD  (PR3CST,LTH=8)
         MFLD  (PR3PRF,LTH=8)
