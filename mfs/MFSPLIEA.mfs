         DFLD  ET7CAR,POS=(15,39),LTH=8,ATTR=(PROT,NORM)
         DFLD  ET7SHP,POS=(15,48),LTH=10,ATTR=(PROT,NORM)
         DFLD  ET7ETA,POS=(15,59),LTH=10,ATTR=(PROT,NORM)
         DFLD  ET7STS,POS=(15,70),LTH=8,ATTR=(PROT,NORM)
*
* --- ROW 16: SEPARATOR ---
         DFLD  '----------',POS=(16,1),ATTR=(PROT,NORM),LTH=80
*
* --- ROW 17-18: TRANSIT DETAIL ---
         DFLD  'DETAIL FOR VIN:',POS=(17,1),ATTR=(PROT,BRT)
         DFLD  SELVIN,POS=(17,17),LTH=17,ATTR=(UNPROT,ALPHA)
         DFLD  TRNDTL,POS=(18,1),LTH=60,ATTR=(PROT,NORM)
*
* --- ROW 22: SEPARATOR ---
         DFLD  ' ',POS=(22,1),ATTR=(PROT,NORM)
*
* --- ROW 23: PF KEY LEGEND ---
         DFLD  'PF3=RETURN  PF7=PREV  PF8=NEXT',POS=(23,1),             X
               ATTR=(PROT,BRT)
*
