*---------------------------------------------------------------*
*  MFS SCREEN: CUSTOMER SEARCH/INQUIRY                           *
*  TRANSACTION: AUTOCIQ                                          *
*  DESCRIPTION: Search customers by name, phone, or DL number   *
*---------------------------------------------------------------*
         PRINT NOGEN
*
* MESSAGE INPUT DESCRIPTOR
*
CUSINI   MID
         SEG
         MFLD  'AUTOCIQ ',LTH=8
         MFLD  SRCLAST,LTH=20
         MFLD  SRCFRST,LTH=15
         MFLD  SRCPHON,LTH=12
         MFLD  SRCDL,LTH=15
         MFLD  SELLIN,LTH=2
         MSGEND
*
* MESSAGE OUTPUT DESCRIPTOR
*
CUSINO   MOD
         SEG
         MFLD  (SRCLAST,LTH=20)
         MFLD  (SRCFRST,LTH=15)
         MFLD  (SRCPHON,LTH=12)
         MFLD  (SRCDL,LTH=15)
         MFLD  (PAGECUR,LTH=4)
         MFLD  (PAGETOT,LTH=4)
         MFLD  (TOTCNT,LTH=5)
*        10 RESULT LINES
         MFLD  (CID01,LTH=8)
         MFLD  (CNAM01,LTH=25)
         MFLD  (CPHN01,LTH=12)
         MFLD  (CCST01,LTH=15)
         MFLD  (CTYP01,LTH=4)
         MFLD  (CDLR01,LTH=5)
         MFLD  (CID02,LTH=8)
         MFLD  (CNAM02,LTH=25)
         MFLD  (CPHN02,LTH=12)
         MFLD  (CCST02,LTH=15)
         MFLD  (CTYP02,LTH=4)
