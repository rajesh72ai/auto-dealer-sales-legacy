         MFLD  (CNAM07,LTH=25)
         MFLD  (CPHN07,LTH=12)
         MFLD  (CCST07,LTH=15)
         MFLD  (CTYP07,LTH=4)
         MFLD  (CDLR07,LTH=5)
         MFLD  (CID08,LTH=8)
         MFLD  (CNAM08,LTH=25)
         MFLD  (CPHN08,LTH=12)
         MFLD  (CCST08,LTH=15)
         MFLD  (CTYP08,LTH=4)
         MFLD  (CDLR08,LTH=5)
         MFLD  (CID09,LTH=8)
         MFLD  (CNAM09,LTH=25)
         MFLD  (CPHN09,LTH=12)
         MFLD  (CCST09,LTH=15)
         MFLD  (CTYP09,LTH=4)
         MFLD  (CDLR09,LTH=5)
         MFLD  (CID10,LTH=8)
         MFLD  (CNAM10,LTH=25)
         MFLD  (CPHN10,LTH=12)
         MFLD  (CCST10,LTH=15)
         MFLD  (CTYP10,LTH=4)
         MFLD  (CDLR10,LTH=5)
         MFLD  (MSGTEXT,LTH=79)
         MSGEND
*
* DEVICE INPUT FORMAT
*
CUSINDIF DIF   TYPE=3270-A2
         DEV   TYPE=3270-A2,FEAT=IGNORE,DSCA=X'00A0'
         DIV   TYPE=INOUT
         DPAGE CURSOR=((4,18))
*
* --- ROW 1: SCREEN TITLE ---
         DFLD  '            AUTOSALES - AUTOMOTIVE DEALER SALES SYSTEM',     X
               POS=(1,1),ATTR=(PROT,BRT)
*
* --- ROW 2: SUBTITLE ---
         DFLD  '                     CUSTOMER SEARCH/INQUIRY',               X
               POS=(2,1),ATTR=(PROT,BRT)
*
* --- ROW 3: SEPARATOR ---
         DFLD  '----------',POS=(3,1),ATTR=(PROT,NORM),LTH=80
*
* --- ROWS 4-6: SEARCH CRITERIA ---
         DFLD  'LAST NAME:',POS=(4,5),ATTR=(PROT,BRT)
         DFLD  SRCLAST,POS=(4,18),LTH=20,ATTR=(UNPROT,ALPHA)
         DFLD  'FIRST NAME:',POS=(4,42),ATTR=(PROT,BRT)
         DFLD  SRCFRST,POS=(4,54),LTH=15,ATTR=(UNPROT,ALPHA)
*
         DFLD  'PHONE:',POS=(5,5),ATTR=(PROT,BRT)
         DFLD  SRCPHON,POS=(5,18),LTH=12,ATTR=(UNPROT,ALPHA)
         DFLD  'DRIVER LIC:',POS=(5,35),ATTR=(PROT,BRT)
         DFLD  SRCDL,POS=(5,47),LTH=15,ATTR=(UNPROT,ALPHA)
*
         DFLD  'SEL:',POS=(6,5),ATTR=(PROT,BRT)
         DFLD  SELLIN,POS=(6,10),LTH=2,ATTR=(UNPROT,NUM)
         DFLD  'PAGE:',POS=(6,20),ATTR=(PROT,NORM)
         DFLD  PAGECUR,POS=(6,26),LTH=4,ATTR=(PROT,NORM)
         DFLD  'OF',POS=(6,31),ATTR=(PROT,NORM)
         DFLD  PAGETOT,POS=(6,34),LTH=4,ATTR=(PROT,NORM)
         DFLD  'TOTAL:',POS=(6,45),ATTR=(PROT,NORM)
         DFLD  TOTCNT,POS=(6,52),LTH=5,ATTR=(PROT,NORM)
*
* --- ROW 7: SEPARATOR ---
         DFLD  ' ',POS=(7,1),ATTR=(PROT,NORM)
*
* --- ROW 8-9: COLUMN HEADERS ---
         DFLD  'LN CUST-ID  NAME                      PHONE        CITX
               Y/STATE     TYPE DLR',POS=(8,1),ATTR=(PROT,BRT)
         DFLD  '-- --------  -------------------------  ------------  --X
               ----------- ---- -----',POS=(9,1),ATTR=(PROT,NORM)
*
* --- ROWS 10-19: RESULT LINES (10 CUSTOMERS) ---
         DFLD  '01',POS=(10,1),ATTR=(PROT,NORM)
         DFLD  CID01,POS=(10,4),LTH=8,ATTR=(PROT,NORM)
