         MFLD  (FPMOD8,LTH=12)
         MFLD  (FPFDT8,LTH=10)
         MFLD  (FPDAY8,LTH=4)
         MFLD  (FPBAL8,LTH=10)
         MFLD  (FPINT8,LTH=8)
         MFLD  (FPST08,LTH=6)
*        TOTALS
         MFLD  (TTLBAL,LTH=12)
         MFLD  (TTLINT,LTH=10)
         MFLD  (MSGTEXT,LTH=79)
         MSGEND
*
* DEVICE INPUT FORMAT
*
FPLINDIF DIF   TYPE=3270-A2
         DEV   TYPE=3270-A2,FEAT=IGNORE,DSCA=X'00A0'
         DIV   TYPE=INOUT
         DPAGE CURSOR=((4,11))
*
* --- ROW 1: SCREEN TITLE ---
         DFLD  '            AUTOSALES - AUTOMOTIVE DEALER SALES SYSTEM',       X
               POS=(1,1),ATTR=(PROT,BRT)
*
* --- ROW 2: SUBTITLE ---
         DFLD  '                       FLOOR PLAN INQUIRY',                    X
               POS=(2,1),ATTR=(PROT,BRT)
*
* --- ROW 3: SEPARATOR ---
         DFLD  '----------',POS=(3,1),ATTR=(PROT,NORM),LTH=80
*
* --- ROW 4-5: SEARCH FIELDS ---
         DFLD  'DEALER:',POS=(4,1),ATTR=(PROT,BRT)
         DFLD  DLRCOD,POS=(4,11),LTH=5,ATTR=(UNPROT,ALPHA)
         DFLD  DLRNAM,POS=(4,17),LTH=25,ATTR=(PROT,NORM)
         DFLD  'VIN:',POS=(5,1),ATTR=(PROT,BRT)
         DFLD  SRCHVN,POS=(5,6),LTH=17,ATTR=(UNPROT,ALPHA)
         DFLD  'STATUS:',POS=(5,26),ATTR=(PROT,BRT)
         DFLD  SRCHST,POS=(5,34),LTH=8,ATTR=(UNPROT,ALPHA)
         DFLD  'LENDER:',POS=(5,45),ATTR=(PROT,BRT)
         DFLD  SRCHLR,POS=(5,53),LTH=8,ATTR=(UNPROT,ALPHA)
*
* --- ROW 6: PAGE INFO ---
         DFLD  'PAGE:',POS=(6,60),ATTR=(PROT,NORM)
         DFLD  PAGNUM,POS=(6,66),LTH=3,ATTR=(PROT,NORM)
         DFLD  'OF',POS=(6,70),ATTR=(PROT,NORM)
         DFLD  PAGMAX,POS=(6,73),LTH=3,ATTR=(PROT,NORM)
*
* --- ROW 7: SEPARATOR ---
         DFLD  '----------',POS=(7,1),ATTR=(PROT,NORM),LTH=80
*
* --- ROW 8: COLUMN HEADERS ---
         DFLD  'VIN               MODEL        FLOOR DT   DAYS BALANCE',      X
               POS=(8,1),ATTR=(PROT,BRT)
         DFLD  '   INTEREST STATUS',POS=(8,58),ATTR=(PROT,BRT)
*
* --- ROWS 9-16: LIST LINES ---
