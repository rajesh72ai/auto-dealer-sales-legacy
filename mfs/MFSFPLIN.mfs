         MFLD  (FPMOD5,LTH=12)
         MFLD  (FPFDT5,LTH=10)
         MFLD  (FPDAY5,LTH=4)
         MFLD  (FPBAL5,LTH=10)
         MFLD  (FPINT5,LTH=8)
         MFLD  (FPST05,LTH=6)
