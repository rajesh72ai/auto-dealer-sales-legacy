*---------------------------------------------------------------*
*  MFS SCREEN: FLOOR PLAN INQUIRY                                *
*  TRANSACTION: AUTOFPIN                                         *
*  DESCRIPTION: Floor plan inventory inquiry with scrolling      *
*---------------------------------------------------------------*
         PRINT NOGEN
*
* MESSAGE INPUT DESCRIPTOR
*
FPLINI   MID
         SEG
         MFLD  'AUTOFPIN',LTH=8
         MFLD  DLRCOD,LTH=5
         MFLD  SRCHVN,LTH=17
         MFLD  SRCHST,LTH=8
         MFLD  SRCHLR,LTH=8
         MFLD  PAGEACT,LTH=1
         MSGEND
*
* MESSAGE OUTPUT DESCRIPTOR
*
FPLINO   MOD
         SEG
         MFLD  (DLRCOD,LTH=5)
         MFLD  (DLRNAM,LTH=25)
         MFLD  (SRCHVN,LTH=17)
         MFLD  (SRCHST,LTH=8)
         MFLD  (SRCHLR,LTH=8)
         MFLD  (PAGNUM,LTH=3)
         MFLD  (PAGMAX,LTH=3)
*        LIST LINES 1-8
         MFLD  (FPVIN1,LTH=17)
         MFLD  (FPMOD1,LTH=12)
         MFLD  (FPFDT1,LTH=10)
         MFLD  (FPDAY1,LTH=4)
         MFLD  (FPBAL1,LTH=10)
         MFLD  (FPINT1,LTH=8)
         MFLD  (FPST01,LTH=6)
         MFLD  (FPVIN2,LTH=17)
         MFLD  (FPMOD2,LTH=12)
         MFLD  (FPFDT2,LTH=10)
         MFLD  (FPDAY2,LTH=4)
         MFLD  (FPBAL2,LTH=10)
