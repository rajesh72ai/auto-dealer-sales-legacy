         MFLD  (FPMOD6,LTH=12)
         MFLD  (FPFDT6,LTH=10)
         MFLD  (FPDAY6,LTH=4)
         MFLD  (FPBAL6,LTH=10)
         MFLD  (FPINT6,LTH=8)
         MFLD  (FPST06,LTH=6)
         MFLD  (FPVIN7,LTH=17)
         MFLD  (FPMOD7,LTH=12)
         MFLD  (FPFDT7,LTH=10)
