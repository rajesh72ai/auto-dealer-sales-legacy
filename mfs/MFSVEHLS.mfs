*
* DEVICE INPUT FORMAT
*
VEHLSDIF DIF   TYPE=3270-A2
         DEV   TYPE=3270-A2,FEAT=IGNORE,DSCA=X'00A0'
         DIV   TYPE=INOUT
         DPAGE CURSOR=((4,18))
*
* --- ROW 1: SCREEN TITLE ---
         DFLD  '            AUTOSALES - AUTOMOTIVE DEALER SALES SYSTEM',     X
               POS=(1,1),ATTR=(PROT,BRT)
*
* --- ROW 2: SUBTITLE ---
         DFLD  '                    VEHICLE INVENTORY LISTING',              X
               POS=(2,1),ATTR=(PROT,BRT)
*
* --- ROW 3: SEPARATOR ---
         DFLD  '----------',POS=(3,1),ATTR=(PROT,NORM),LTH=80
*
* --- ROW 4-5: FILTER FIELDS ---
         DFLD  'DEALER:',POS=(4,2),ATTR=(PROT,BRT)
         DFLD  FLTDLR,POS=(4,10),LTH=5,ATTR=(UNPROT,ALPHA)
         DFLD  'YEAR:',POS=(4,18),ATTR=(PROT,BRT)
         DFLD  FLTYR,POS=(4,24),LTH=4,ATTR=(UNPROT,NUM)
         DFLD  'MAKE:',POS=(4,31),ATTR=(PROT,BRT)
         DFLD  FLTMAK,POS=(4,37),LTH=5,ATTR=(UNPROT,ALPHA)
         DFLD  'MODEL:',POS=(4,45),ATTR=(PROT,BRT)
         DFLD  FLTMDL,POS=(4,52),LTH=5,ATTR=(UNPROT,ALPHA)
         DFLD  'STATUS:',POS=(4,60),ATTR=(PROT,BRT)
         DFLD  FLTSTS,POS=(4,68),LTH=1,ATTR=(UNPROT,ALPHA)
*
         DFLD  'SEL:',POS=(5,2),ATTR=(PROT,BRT)
         DFLD  SELLIN,POS=(5,7),LTH=2,ATTR=(UNPROT,NUM)
         DFLD  'PAGE:',POS=(5,20),ATTR=(PROT,NORM)
         DFLD  PAGECUR,POS=(5,26),LTH=4,ATTR=(PROT,NORM)
         DFLD  'OF',POS=(5,31),ATTR=(PROT,NORM)
         DFLD  PAGETOT,POS=(5,34),LTH=4,ATTR=(PROT,NORM)
         DFLD  'TOTAL:',POS=(5,45),ATTR=(PROT,NORM)
         DFLD  TOTCNT,POS=(5,52),LTH=6,ATTR=(PROT,NORM)
*
* --- ROW 6: SEPARATOR ---
         DFLD  ' ',POS=(6,1),ATTR=(PROT,NORM)
*
* --- ROW 7: COLUMN HEADERS ---
         DFLD  'LN VIN               STOCK#   YEAR MODEL        COLOR    STX
               S    DAYS LOC',POS=(7,1),ATTR=(PROT,BRT)
         DFLD  '-- ----------------- -------- ---- ------------ -------X
               - ------ ---- --------',POS=(8,1),ATTR=(PROT,NORM)
