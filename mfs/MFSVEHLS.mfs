*---------------------------------------------------------------*
*  MFS SCREEN: VEHICLE INVENTORY LISTING                         *
*  TRANSACTION: AUTOVLS                                          *
*  DESCRIPTION: Scrollable vehicle inventory list with filters   *
*---------------------------------------------------------------*
         PRINT NOGEN
*
* MESSAGE INPUT DESCRIPTOR
*
VEHLSI   MID
         SEG
         MFLD  'AUTOVLS ',LTH=8
         MFLD  FLTDLR,LTH=5
         MFLD  FLTYR,LTH=4
         MFLD  FLTMAK,LTH=5
         MFLD  FLTMDL,LTH=5
         MFLD  FLTSTS,LTH=1
         MFLD  SELLIN,LTH=2
         MSGEND
*
* MESSAGE OUTPUT DESCRIPTOR
*
VEHLSO   MOD
         SEG
         MFLD  (FLTDLR,LTH=5)
         MFLD  (FLTYR,LTH=4)
         MFLD  (FLTMAK,LTH=5)
         MFLD  (FLTMDL,LTH=5)
         MFLD  (FLTSTS,LTH=1)
         MFLD  (PAGECUR,LTH=4)
         MFLD  (PAGETOT,LTH=4)
         MFLD  (TOTCNT,LTH=6)
