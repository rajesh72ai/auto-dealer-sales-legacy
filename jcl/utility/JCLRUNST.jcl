      LIB('DSNLOAD')
  END
//SYSIN    DD *
  RUNSTATS TABLESPACE AUTODB.TSVEHICL
    TABLE(ALL) INDEX(ALL) SHRLEVEL CHANGE
    UPDATE ALL REPORT YES;
  RUNSTATS TABLESPACE AUTODB.TSSTKHST
    TABLE(ALL) INDEX(ALL) SHRLEVEL CHANGE
    UPDATE ALL REPORT YES;
