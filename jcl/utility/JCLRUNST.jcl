//*********************************************************************
//* JCL:      JCLRUNST
//* SYSTEM:   AUTOSALES - AUTOMOTIVE DEALER SALES & REPORTING
//* PURPOSE:  DB2 RUNSTATS FOR ALL TABLESPACES
//*           COLLECTS STATISTICS ON ALL AUTOSALES TABLESPACES
//*           AND INDEXES FOR DB2 OPTIMIZER ACCURACY
//* SCHEDULE: WEEKLY SUNDAY 04:00 CST
//* ON ERROR: CONTACT DBA - STALE STATS DEGRADE PERFORMANCE
//*********************************************************************
//AUTOSLU2 JOB (ACCT),'AUTOSALES-RUNST',CLASS=A,MSGCLASS=H,
//          MSGLEVEL=(1,1),NOTIFY=&SYSUID,
//          REGION=0M,TIME=60
//*
//JOBLIB   DD DSN=DSNLOAD,DISP=SHR
//*
//*-------------------------------------------------------------------
//* STEP010 - RUNSTATS ON REFERENCE TABLESPACES
//*-------------------------------------------------------------------
//RUNSTREF EXEC PGM=IKJEFT01,DYNAMNBR=20
//SYSTSPRT DD SYSOUT=*
//SYSTSIN  DD *
  DSN SYSTEM(DBAG)
  RUN PROGRAM(DSNTIAD) PLAN(DSNTIAD) -
      LIB('DSNLOAD')
  END
//SYSIN    DD *
  RUNSTATS TABLESPACE AUTODB.TSSYSUSE
    TABLE(ALL) INDEX(ALL) SHRLEVEL CHANGE
    UPDATE ALL REPORT YES;
  RUNSTATS TABLESPACE AUTODB.TSDEALER
    TABLE(ALL) INDEX(ALL) SHRLEVEL CHANGE
    UPDATE ALL REPORT YES;
  RUNSTATS TABLESPACE AUTODB.TSMODEL
    TABLE(ALL) INDEX(ALL) SHRLEVEL CHANGE
    UPDATE ALL REPORT YES;
/*
//*
//*-------------------------------------------------------------------
//* STEP020 - RUNSTATS ON VEHICLE/INVENTORY TABLESPACES
//*-------------------------------------------------------------------
//RUNSTVEH EXEC PGM=IKJEFT01,DYNAMNBR=20,
//         COND=(4,LT,RUNSTREF)
//SYSTSPRT DD SYSOUT=*
//SYSTSIN  DD *
  DSN SYSTEM(DBAG)
