# AutoSales — local environment template.
# Copy to `.env` and fill in real values. `.env` is in .gitignore; NEVER commit real keys.

# --- Database (dev defaults fine) ---
POSTGRES_DB=autosales
POSTGRES_USER=autosales
POSTGRES_PASSWORD=autosales

# --- Auth ---
JWT_SECRET=autosales-dev-secret-key-must-be-at-least-256-bits-long-for-hs256

# --- Free-tier LLMs for the blue "AI Assistant" ---
GROQ_API_KEY=
GEMINI_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=

# --- Anthropic (violet "AI Agent" via OpenClaw) ---
# Standard API key. Starts with `sk-ant-api03-...`
CLAUDE_API_KEY=

# --- Anthropic Admin API (OPTIONAL, dangerous) ---
# Starts with `sk-ant-admin-...`. Powers /admin/agent-usage dashboard only.
# Grants org-wide authority (billing, workspaces, rate limits). Remains active
# after creator is removed. Provision in Anthropic Console → Admin Keys.
# LEAVE UNSET if you don't need the org-level billing dashboard.
ANTHROPIC_ADMIN_API_KEY=
